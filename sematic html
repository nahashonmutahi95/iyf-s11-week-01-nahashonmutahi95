<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Semantic HTML Conversion</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
        }

        header {
            background-color: #2c3e50;
            color: white;
            padding: 1rem 0;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        header h1 {
            margin: 0;
            padding: 0 2rem;
            font-size: 1.8rem;
        }

        nav {
            background-color: #34495e;
            padding: 0;
        }

        nav ul {
            list-style: none;
            display: flex;
            padding: 0 2rem;
        }

        nav li {
            margin: 0;
        }

        nav a {
            display: block;
            color: white;
            text-decoration: none;
            padding: 1rem 1.5rem;
            transition: background-color 0.3s ease;
        }

        nav a:hover {
            background-color: #2c3e50;
        }

        main {
            display: flex;
            max-width: 1200px;
            margin: 2rem auto;
            gap: 2rem;
            padding: 0 2rem;
        }

        article {
            flex: 2;
        }

        article h2 {
            color: #2c3e50;
            margin-bottom: 1rem;
            font-size: 1.5rem;
        }

        article p {
            margin-bottom: 1rem;
            text-align: justify;
        }

        aside {
            flex: 1;
            background-color: #ecf0f1;
            padding: 1.5rem;
            border-radius: 5px;
            height: fit-content;
        }

        aside h3 {
            color: #2c3e50;
            margin-bottom: 1rem;
            font-size: 1.2rem;
        }

        aside ul {
            list-style: none;
        }

        aside li {
            padding: 0.5rem 0;
            border-bottom: 1px solid #bdc3c7;
        }

        aside li:last-child {
            border-bottom: none;
        }

        aside a {
            color: #3498db;
            text-decoration: none;
        }

        aside a:hover {
            text-decoration: underline;
        }

        footer {
            background-color: #2c3e50;
            color: white;
            text-align: center;
            padding: 2rem;
            margin-top: 2rem;
        }

        footer p {
            margin: 0;
        }

        @media (max-width: 768px) {
            main {
                flex-direction: column;
            }

            nav ul {
                flex-direction: column;
                padding: 0;
            }

            nav a {
                padding: 0.75rem 1rem;
            }
        }
    </style>
</head>
<body>
    <!-- Semantic Header with Navigation -->
    <header>
        <h1>My Site</h1>
    </header>

    <nav>
        <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- Semantic Main Content -->
    <main>
        <!-- Article Section -->
        <article>
            <h2>Welcome to My Site</h2>
            <p>This is my first paragraph. This section contains the main content of the page, properly structured using semantic HTML elements like <code>&lt;article&gt;</code> to indicate that this is the primary content area.</p>
            <p>This is my second paragraph. Using semantic HTML improves accessibility, SEO, and makes the code more maintainable. The <code>&lt;article&gt;</code> element is appropriate for independent content blocks like blog posts, news articles, or main page content.</p>
        </article>

        <!-- Sidebar Section -->
        <aside>
            <h3>Recent Posts</h3>
            <ul>
                <li><a href="#post1">Understanding Semantic HTML</a></li>
                <li><a href="#post2">Web Accessibility Best Practices</a></li>
                <li><a href="#post3">CSS Grid vs Flexbox</a></li>
                <li><a href="#post4">JavaScript ES6 Features</a></li>
            </ul>
        </aside>
    </main>

    <!-- Semantic Footer -->
    <footer>
        <p>&copy; 2026 My Site. All rights reserved.</p>
    </footer>
</body>
</html>
